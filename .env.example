# Copy this file to .env and fill in real values. NEVER commit your real .env.
# Generate strong secrets, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-different-long-random-string
JWT_EXP_HOURS=12

# Database.
# With docker-compose.yml (the bundled stack), DB_PASSWORD sets the password
# for BOTH the postgres container and the app — set a strong value in production.
# The DB_HOST/PORT/USER/NAME below are only used when running WITHOUT Docker
# (e.g. `python server.py` against a local postgres); in Docker they are wired
# to the `db` service automatically.
DB_HOST=localhost
DB_PORT=5432
DB_USER=voting
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=votingdb
DB_SSLMODE=disable
DB_POOL_MIN=1
DB_POOL_MAX=20

# App
PORT=8000
FLASK_DEBUG=0

# Optional: shared rate-limit storage for multi-worker deployments
# RATELIMIT_STORAGE_URI=redis://localhost:6379
